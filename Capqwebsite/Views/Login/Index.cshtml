@{
	Layout = null;
}


<link href="~/fontawesome-free-5.15.4-web/css/all.min.css" rel="stylesheet" />
<link href="~/css/login.css" rel="stylesheet" />

<main class="auth-page" dir="rtl">
	<section class="auth-card">
		<div class="auth-brand">
			<div class="auth-logo-wrap">
				<img src="~/img/logo-capq2.png" alt="شعار الحجر الزراعي" class="auth-logo" />
			</div>
			<p>وزارة الزراعة واستصلاح الأراضي</p>
			<h1>الإدارة المركزية للحجر الزراعي</h1>
			<span>منظومة لجان فحص الوارد</span>
		</div>

		<div class="auth-form-panel">
			<div class="auth-heading">
				<h2>تسجيل الدخول</h2>
				<p>أدخل بيانات حسابك للوصول إلى مهام اليوم</p>
			</div>

			@if (ViewBag.LoginError != null)
			{
				<div class="auth-error" role="alert">
					<i class="fas fa-exclamation-circle"></i>
					<span>@ViewBag.LoginError</span>
				</div>
			}

			<form class="auth-form" method="post" asp-controller="Login" asp-action="GoDataEntryMenu">
				@Html.AntiForgeryToken()
				<label for="userName">اسم المستخدم</label>
				<div class="auth-input-wrap">
					<i class="fas fa-user"></i>
					<input id="userName" name="userName" type="text" placeholder="اكتب اسم المستخدم" autocomplete="username" autofocus required />
				</div>

				<label for="password">كلمة المرور</label>
				<div class="auth-input-wrap">
					<i class="fas fa-lock"></i>
					<input id="password" name="password" type="password" placeholder="اكتب كلمة المرور" autocomplete="current-password" required />
				</div>

				<button class="auth-submit" type="submit">
					<span>دخول إلى النظام</span>
					<i class="fas fa-arrow-left"></i>
				</button>
			</form>
		</div>
	</section>
</main>
