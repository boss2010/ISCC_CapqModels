@model ViewModels.ListImPermissionFilterVm
@{
    ViewData["Title"] = "أذون الاستيراد";
}

<div class="container-fluid py-4" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="text-primary mb-1">أذون الاستيراد</h2>
            <div class="text-muted">يتم عرض آخر 7 أيام تلقائيًا، ويمكن تعديل فترة البحث.</div>
        </div>
        <a asp-controller="ImportRequests" asp-action="Index" class="btn btn-outline-secondary">العودة للطلبات</a>
    </div>

    @if (ViewBag.PageError is string pageError)
    {
        <div class="alert alert-danger">@pageError</div>
    }

    <form method="get" asp-controller="ListIm_Permission" asp-action="Index" class="card shadow-sm mb-4">
        <div class="card-header bg-dark text-white">فلاتر البحث</div>
        <div class="card-body">
            <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
            <div class="row g-3">
                <div class="col-lg-2 col-md-4">
                    <label class="form-label fw-bold" for="fromDate">من تاريخ</label>
                    <input class="form-control" id="fromDate" name="fromDate" type="date" value="@Model.FromDate.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-lg-2 col-md-4">
                    <label class="form-label fw-bold" for="toDate">إلى تاريخ</label>
                    <input class="form-control" id="toDate" name="toDate" type="date" value="@Model.ToDate.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-lg-2 col-md-4">
                    <label class="form-label fw-bold" for="permissionNumber">رقم الإذن أو جزء منه</label>
                    <input class="form-control" id="permissionNumber" name="permissionNumber" value="@Model.PermissionNumber" placeholder="مثال: 123" />
                </div>
                <div class="col-lg-2 col-md-4">
                    <label class="form-label fw-bold" for="country">الدولة</label>
                    <input class="form-control" id="country" name="country" value="@Model.Country" placeholder="اسم الدولة أو جزء منه" />
                </div>
                <div class="col-lg-2 col-md-4">
                    <label class="form-label fw-bold" for="company">الشركة</label>
                    <input class="form-control" id="company" name="company" value="@Model.Company" placeholder="اسم الشركة أو جزء منه" />
                </div>
                <div class="col-lg-2 col-md-4">
                    <label class="form-label fw-bold" for="shortName">الاسم المختصر</label>
                    <input class="form-control" id="shortName" name="shortName" value="@Model.ShortName" placeholder="الاسم أو جزء منه" />
                </div>
            </div>
            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary px-4"><i class="fas fa-search"></i> بحث</button>
                <a asp-controller="ListIm_Permission" asp-action="Index" class="btn btn-outline-secondary">آخر 7 أيام</a>
            </div>
        </div>
    </form>

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>نتائج البحث</strong>
            <span class="badge bg-info text-dark">@Model.Results.Count نتيجة</span>
        </div>
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>رقم الإذن</th>
                        <th>تاريخ الوصول</th>
                        <th>بداية الإذن</th>
                        <th>نهاية الإذن</th>
                        <th>الدولة</th>
                        <th>الشركة</th>
                        <th>الاسم المختصر</th>
                        <th>نوع العملية</th>
                        <th>الحالة</th>
                        <th>الدفع</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Results.Count == 0)
                    {
                        <tr><td colspan="10" class="text-center text-muted py-4">لا توجد نتائج مطابقة للفلاتر المختارة.</td></tr>
                    }
                    else
                    {
                        @foreach (var item in Model.Results)
                        {
                            <tr>
                                <td class="fw-bold"><a href="@Url.Content($"~/Im_Permissions/Im_permissionDetail/Index?ImPermission_Number={Uri.EscapeDataString(item.PermissionNumber)}")" class="text-primary">@(string.IsNullOrWhiteSpace(item.PermissionNumber) ? "—" : item.PermissionNumber)</a></td>
                                <td>@item.ArrivalDate.ToString("yyyy/MM/dd")</td>
                                <td>@(item.StartDate?.ToString("yyyy/MM/dd") ?? "—")</td>
                                <td>@(item.EndDate?.ToString("yyyy/MM/dd") ?? "—")</td>
                                <td>@(string.IsNullOrWhiteSpace(item.Country) ? "—" : item.Country)</td>
                                <td><div>@(string.IsNullOrWhiteSpace(item.Company) ? "—" : item.Company)</div><small class="text-muted">@item.ImporterType</small></td>
                                <td>@(string.IsNullOrWhiteSpace(item.ShortName) ? "—" : item.ShortName)</td>
                                <td>@(string.IsNullOrWhiteSpace(item.OperationType) ? "—" : item.OperationType)</td>
                                <td>
                                    @if (item.IsAccepted == true) { <span class="badge bg-success">مقبول</span> }
                                    else if (item.IsAccepted == false) { <span class="badge bg-danger">مرفوض</span> }
                                    else { <span class="badge bg-secondary">تحت الإجراء</span> }
                                </td>
                                <td>@if (item.IsPaid == true) { <span class="badge bg-success">تم الدفع</span> } else { <span class="badge bg-warning text-dark">غير مدفوع</span> }</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
